{
  "name": "unidicas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:images": "node scripts/check-images.mjs",
    "ofertas:db:migrate": "node --env-file=.env.local scripts/migrate-ofertas-to-supabase.mjs",
    "ofertas:db:verify": "node --env-file=.env.local scripts/verify-ofertas.mjs",
    "ofertas:db:apply-schema": "node --env-file=.env.local scripts/apply-schema.mjs",
    "ofertas:db:verify-schema": "node --env-file=.env.local scripts/verify-schema.mjs",
    "ofertas:db:fix-schema": "node --env-file=.env.local scripts/fix-schema-drift.mjs",
    "ofertas:db:smoke-anon": "node --env-file=.env.local scripts/smoke-anon.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.9",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
